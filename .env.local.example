UPSTASH_REDIS_REST_TOKEN=AZxx...

# â”€â”€ hCaptcha â€” protecciÃ³n anti-bot en formularios â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€â”€
# ObtÃ©n tus claves en: https://dashboard.hcaptcha.com/
# NEXT_PUBLIC_ porque se usa en el componente cliente.
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001

# Solo servidor â€” secret para verificar tokens
HCAPTCHA_SECRET_KEY=0x0000000000000000000000000000000000000000

# Desactivar hCaptcha en emergencias sin redeploy (opcional, valores: true / false)
# NEXT_PUBLIC_HCAPTCHA_DISABLED=false


# NTFY - notificaciones de pedidos (opcional)
# Crea un topic gratuito en: https://ntfy.sh
NTFY_TOPIC=healzyp-orders

