# ============================================================================
# Variables de entorno — copia este archivo como .env.local y rellena los valores
# NUNCA subas .env.local a git (ya está en .gitignore)
# ============================================================================

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# Project Settings → API → anon / public key (segura para el cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Project Settings → API → service_role / secret key (SOLO SERVIDOR — nunca NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Mapbox — autocompletado de direcciones (España) ──────────────────────────
# Obtén tu token en: https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=pk.ey...

# ── Stripe — pago con tarjeta ─────────────────────────────────────────────────
# Obtén tus claves en: https://dashboard.stripe.com/apikeys
# Usa claves de TEST (pk_test_ / sk_test_) en desarrollo
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Solo servidor — no añadir prefijo NEXT_PUBLIC_
STRIPE_SECRET_KEY=sk_test_...

# Webhook secret para verificar eventos de Stripe
# Obtén el secret en: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

