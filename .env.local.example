# ============================================================================
# Variables de entorno — copia este archivo como .env.local y rellena los valores
# NUNCA subas .env.local a git (ya está en .gitignore)
# ============================================================================

# ── Supabase ────────────────────────────────────────────────────────────────
# Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=ht

# Project Settings → API → anon / public key (segura para el cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ

# Project Settings → API → service_role / secret key (SOLO SERVIDOR — nunca NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=eyJ

# ── Mapbox — autocompletado de direcciones (España) ─────────────────────────
# Obtén tu token en: https://account.mapbox.com/
NEXT_PUBLIC_MAPBOX_TOKEN=pk..-hbA

# ── Stripe — pago con tarjeta ───────────────────────────────────────────────
# Obtén tus claves en: https://dashboard.stripe.com/apikeys
# Usa claves de TEST (pk_test_ / sk_test_) en desarrollo
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_51

# Solo servidor — no añadir prefijo NEXT_PUBLIC_
STRIPE_SECRET_KEY=sk_li
# Webhook secret para verificar eventos de Stripe
# Obtén el secret en: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=wh

# ── Upstash Redis — Rate limiting distribuido ───────────────────────────────
# Crea una base de datos gratuita en: https://console.upstash.com/
# Requerido para que el rate limiting funcione correctamente en Vercel.
UPSTASH_REDIS_REST_URL=https://xxxxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AZxx...

# ── hCaptcha — protección anti-bot en formularios ───────────────────────────
# Obtén tus claves en: https://dashboard.hcaptcha.com/
# NEXT_PUBLIC_ porque se usa en el componente cliente.
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001

# Solo servidor — secret para verificar tokens
HCAPTCHA_SECRET_KEY=0x0000000000000000000000000000000000000000

# Desactivar hCaptcha en emergencias sin redeploy (opcional, valores: true / false)
# NEXT_PUBLIC_HCAPTCHA_DISABLED=false

# ── Telegram — notificaciones de pedidos (opcional) ─────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=-1001234567890


# ── Meta Pixel + Conversions API (CAPI) ─────────────────────────────────────
# Obtén tu Pixel ID en: https://business.facebook.com/events_manager
# NEXT_PUBLIC_ porque el script se carga en el navegador.
NEXT_PUBLIC_META_PIXEL_ID=1234567890123456

# Access Token para CAPI (server-side only)
# Crea un token en Events Manager → Configuración → Token de acceso de conversión
META_CAPI_ACCESS_TOKEN=EAxxxxxxxxxx
